{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Q+",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#macros" },
        { "include": "#attributes" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#functions" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.qplus",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.qplus",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.qplus",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.qplus",
                            "match": "\\\\(x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]{1,6}\\}|[nrt\\\\'\"])"
                        }
                    ]
                },
                {
                    "name": "string.quoted.raw.qplus",
                    "begin": "r\"",
                    "end": "\""
                },
                {
                    "name": "string.quoted.single.qplus",
                    "match": "'([^'\\\\]|\\\\.)'"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.qplus",
                    "match": "\\b0x[0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.qplus",
                    "match": "\\b0b[01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.qplus",
                    "match": "\\b0o[0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.qplus",
                    "match": "\\b[0-9_]+\\.[0-9_]+([eE][+-]?[0-9_]+)?(f32|f64)?\\b"
                },
                {
                    "name": "constant.numeric.decimal.qplus",
                    "match": "\\b[0-9_]+(u8|i8|u16|i16|u32|i32|u64|i64|usize|isize)?\\b"
                }
            ]
        },
        "macros": {
            "patterns": [
                {
                    "name": "support.function.macro.qplus",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*!"
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.attribute.qplus",
                    "begin": "#\\[",
                    "end": "\\]",
                    "patterns": [
                        {
                            "name": "entity.other.attribute-name.qplus",
                            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                        },
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#numbers"
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.qplus",
                    "match": "\\b(if|else|match|for|while|loop|return|break|continue|defer|in)\\b"
                },
                {
                    "name": "keyword.other.qplus",
                    "match": "\\b(as|unsafe|safe|import|module)\\b"
                },
                {
                    "name": "storage.type.qplus",
                    "match": "\\b(fn|let|const|struct|enum|union|trait|impl|type|driver|syscall|interrupt|static)\\b"
                },
                {
                    "name": "storage.modifier.qplus",
                    "match": "\\b(pub|mut|own|ptr|ref|slice|volatile|mmio|port)\\b"
                },
                {
                    "name": "constant.language.bool.qplus",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.null.qplus",
                    "match": "\\bnull\\b"
                },
                {
                    "name": "variable.language.self.qplus",
                    "match": "\\b(self|Self|kernel)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.qplus",
                    "match": "\\b(u8|i8|u16|i16|u32|i32|u64|i64|usize|isize|f32|f64|bool|char|void)\\b"
                },
                {
                    "name": "entity.name.type.qplus",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.qplus",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.qplus",
                    "match": "\\b(and|or|not)\\b"
                },
                {
                    "name": "keyword.operator.qplus",
                    "match": "(\\+|-|\\*|/|%|==|!=|<|>|<=|>=|=|\\|\\||&&|!|\\?|\\^|&|\\||<<|>>|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|\\.\\.|\\.\\.=)"
                }
            ]
        }
    }
}
