// hello.qp — Minimal Q+ kernel entry point
// Used for testing the lexer.

module kernel;

import kernel::drivers::vga { VGABuffer, Color };
import kernel::drivers::serial { Serial };

const PAGE_SIZE: usize = 4096;
const KERNEL_BASE: u64 = 0xFFFF_FFFF_8000_0000;

#[no_mangle]
#[link_section(".text.boot")]
pub fn _start() -> ! {
    let serial = Serial::init(0x3F8);
    serial.write("Q+ Kernel booting...\n");

    let vga = VGABuffer::get();
    vga.clear(0x00);
    vga.write_at(0, 0, "Q+ OS v0.1", 0x0A);

    loop {
        unsafe { asm!("hlt"); }
    }
}

#[panic_handler]
fn panic(msg: &str) -> ! {
    let serial = Serial::init(0x3F8);
    serial.write("KERNEL PANIC: ");
    serial.write(msg);
    serial.write("\n");
    loop {
        unsafe {
            cpu::disable_interrupts();
            asm!("hlt");
        }
    }
}
